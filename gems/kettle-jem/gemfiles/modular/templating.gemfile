# frozen_string_literal: true

remote = ENV.fetch("KETTLE_RB_DEV", "false").casecmp("false").zero?
structuredmerge_ruby_gems = ENV["STRUCTUREDMERGE_RUBY_GEMS"].to_s.strip

# Cross-platform parsers
gem "parslet"
gem "prism", "~> 1.6"
gem "toml"
gem "unparser", "~> 0.8", ">= 0.8.1"

platform :mri do
  # MRI only Parsers:
  # kettle-jem currently uses markly instead of commonmarker, but these can easily be swapped.
  # gem "commonmarker"
  gem "markly", "~> 0.15", ">= 0.15.3"
  gem "rbs", ">= 3.10"   # ruby >= 3.1.0

  # MRI Backend
  gem "ruby_tree_sitter",
    "~> 2.1",
    require: false # DO NOT LOAD, because conflicts with FFI

  if !structuredmerge_ruby_gems.empty?
    %w[
      tree_haver
      ast-merge
      ruby-merge
      toml-merge
      yaml-merge
      kettle-jem
    ].each do |gem_name|
      gem gem_name, path: File.join(structuredmerge_ruby_gems, gem_name)
    end
  elsif remote
    # AST parsing for advanced templating.
    # Kettle-rb's Merge Recipes (released)
    gem "kettle-jem", ">= 7.0"
  end
end

# Set KETTLE_RB_DEV=true (or path) for local development with path-based dependencies.
# When false (default / CI), released gems are used and explicit parser pins are needed.
# Local path overrides — merge gems bring their own parser dependencies
eval_gemfile "templating_local.gemfile" if !remote && structuredmerge_ruby_gems.empty?
