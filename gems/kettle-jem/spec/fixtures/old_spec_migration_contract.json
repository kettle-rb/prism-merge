{
  "case_id": "kettle-jem-old-spec-migration",
  "ecosystem": "rubygems",
  "cases": {
    "gemspec_self_dependency": {
      "package_name": "my-gem",
      "removed_dependency": "my-gem",
      "preserved_dependency": "addressable",
      "preserved_fields": [
        "summary",
        "homepage",
        "required_ruby_version"
      ]
    },
    "appraisals_custom_blocks": {
      "template_appraisal": "ruby-4-0",
      "destination_appraisal": "custom-local"
    },
    "modular_gemfile_ruby_bucket": {
      "path": "gemfiles/modular/x_std_libs/r4/libs.gemfile",
      "template_eval_paths": [
        "../../erb/r4/v5.0.gemfile",
        "../../mutex_m/r4/v0.3.gemfile",
        "../../stringio/r4/v3.0.gemfile",
        "../../benchmark/r4/v0.5.gemfile"
      ],
      "obsolete_eval_paths": [
        "../../erb/r3/v5.0.gemfile",
        "../../mutex_m/r3/v0.3.gemfile",
        "../../stringio/r3/v3.0.gemfile"
      ]
    },
    "gemfile_comment_and_token_policy": {
      "important_phrase": "Gemfile is for local development ONLY",
      "token": "{KJ|GEM_NAME}",
      "resolved_gem_name": "example",
      "commented_dependency": "irb",
      "active_dependency": "debug"
    },
    "gemspec_emoji_block_integrity": {
      "package_name": "kettle-dev",
      "summary": "🍲 A kettle-rb meta tool",
      "description": "🍲 Kettle::Dev is a meta tool from kettle-rb to streamline development",
      "executable": "kettle-changelog"
    }
  }
}
